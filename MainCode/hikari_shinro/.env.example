# Hikari Shinro AI — Environment Variables
# Copy this file to .env and fill in your values

# Groq API Key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Flask secret key (any random string)
SECRET_KEY=hikari-shinro-super-secret-2026

# Camera device index (0 = default webcam, 1 = external USB cam)
CAMERA_DEVICE=0

# MiDaS model: MiDaS_small | DPT_Hybrid | DPT_Large
MIDAS_MODEL=MiDaS_small

# Whisper model: tiny | base | small
WHISPER_MODEL=base

# YOLO-World model: yolov8s-worldv2 | yolov8m-worldv2
YOLO_MODEL=yolov8s-worldv2
